# ── Claude AI ─────────────────────────────────────────────────
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Model to use (haiku is fastest/cheapest, sonnet is smarter)
# Options: claude-sonnet-4-6 | claude-sonnet-4-6 | claude-opus-4-6
CLAUDE_MODEL=claude-sonnet-4-6

# ── Server ─────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# URL of the React dev server (for CORS in development)
CLIENT_URL=http://localhost:5173
